# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# MongoDB 连接 URI，包含用户名和密码
# 注意：如果你的密码包含特殊字符，需要进行 URL 编码
MONGODB_URI="mongodb://admin:123456@localhost:27017/admin?authSource=admin"

# 你要操作的数据库名称
MONGODB_DB_NAME="NuxtShop"

# 管理员用户名和密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
