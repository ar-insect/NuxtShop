# Production environment variables (example)

# Redis Configuration (production)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=please-change-me
REDIS_DB=0

# MongoDB connection URI (production)
# IMPORTANT: replace with your real managed MongoDB connection string
MONGODB_URI="mongodb://user:strong-password@mongo:27017/admin?authSource=admin"

# Database name to use
MONGODB_DB_NAME="NuxtShop"

# Admin account for backoffice / demo
# IMPORTANT: override these with secure values in real deployments
ADMIN_USERNAME=admin
ADMIN_PASSWORD=please-change-me

# Frontend feature flags
# 0 = enable captcha, 1 = disable captcha
NUXT_PUBLIC_DISABLE_CAPTCHA=0

