# Development environment variables

# Redis Configuration (local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# MongoDB connection URI (local)
# Note: if your password contains special characters, URL-encode it
MONGODB_URI="mongodb://admin:123456@localhost:27017/admin?authSource=admin"

# Database name to use
MONGODB_DB_NAME="NuxtShop"

# Admin account for demo / local development
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

